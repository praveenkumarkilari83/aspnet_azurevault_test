@model KeyVaultTest.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h2 class="text-center mb-4">Login</h2>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger" role="alert">
                            @Html.ValidationSummary(false)
                        </div>
                    }

                    <form method="post" action="@Url.Action("Index", "Login")">
                        <div class="mb-3">
                            <label for="username" class="form-label">Username</label>
                            <input type="text" 
                                   class="form-control @(ViewData.ModelState.ContainsKey("Username") ? "is-invalid" : "")" 
                                   id="username" 
                                   name="Username" 
                                   placeholder="Enter your username"
                                   value="@Model?.Username"
                                   required>
                            <span class="invalid-feedback">
                                @Html.ValidationMessage("Username")
                            </span>
                        </div>

                        <div class="mb-3">
                            <label for="password" class="form-label">Password</label>
                            <input type="password" 
                                   class="form-control @(ViewData.ModelState.ContainsKey("Password") ? "is-invalid" : "")" 
                                   id="password" 
                                   name="Password" 
                                   placeholder="Enter your password"
                                   required>
                            <span class="invalid-feedback">
                                @Html.ValidationMessage("Password")
                            </span>
                        </div>

                        <div class="mb-3 form-check">
                            <input type="checkbox" 
                                   class="form-check-input" 
                                   id="rememberMe" 
                                   name="RememberMe"
                                   @(Model?.RememberMe == true ? "checked" : "")>
                            <label class="form-check-label" for="rememberMe">
                                Remember me
                            </label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 mb-3">Login</button>
                    </form>

                    <hr />

                    <p class="text-center text-muted mb-0">
                        Don't have an account? <a href="#">Sign up here</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .card {
        border: none;
        border-radius: 10px;
    }

    .btn-primary {
        background-color: #667eea;
        border-color: #667eea;
        font-weight: 600;
    }

    .btn-primary:hover {
        background-color: #5568d3;
        border-color: #5568d3;
    }
</style>